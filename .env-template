# URL for application
HOST_API=http://localhost:3000

# Set use HTTPS in conecction database
STAGE=dev

# Postgre SQL data
DB_PORT=5432
DB_USER=postgre user
DB_PASSWORD=postgre password
DB_NAME=postgre database name

# General setup
PAGESIZE=number of items in pagination of gets users

JWT_SECRET=Secreto

# Google Workspace application data
CLIENTID=client id from google cloud app registration
CLIENTSECRET=client secret from google cloud app registration

# Meta developer app
FACEBOOK_APP_ID=Id app in Meta Developer
FACEBOOK_APP_SECRET=Secret key for app in Meta Developer
FACEBOOK_CALLBACKURL=URL expected for login in app in Meta Developer
